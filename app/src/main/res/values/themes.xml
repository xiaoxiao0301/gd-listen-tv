<resources>

    <!-- Base application theme -->
    <style name="Theme.AmberPlay" parent="Theme.AppCompat.DayNight.NoActionBar" />

    <!--
      Splash-screen theme (androidx.core:core-splashscreen).
      Shown while the app initialises; transitions to Theme.AmberPlay afterward.
      Icon: the eighth-note foreground vector, centred on the app's dark background.
    -->
    <style name="Theme.AmberPlay.Splash" parent="Theme.SplashScreen">
        <!-- Dark background matching Background = #0F0F14 -->
        <item name="windowSplashScreenBackground">#0F0F14</item>
        <!-- Eighth-note icon (108×108 foreground vector) -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <!-- Hand off to the real app theme once the splash dismisses -->
        <item name="postSplashScreenTheme">@style/Theme.AmberPlay</item>
    </style>

</resources>